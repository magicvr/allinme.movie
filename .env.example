# Server listen address (default :8080)
ADDR=:8080

# Port exposed on the host (used by docker-compose)
PORT=8080

# SQLite database file path inside the container
DB_PATH=/app/data/movie.db

# Path to the HTML templates directory inside the container
TEMPLATE_DIR=/app/templates

# Site title shown in the frontend (default: AllInMe Movie)
SITE_TITLE=AllInMe Movie

# Collector API base URL (leave empty to disable scheduled collection)
COLLECTOR_API_URL=

# Cron schedule for automatic collection (default: every 6 hours)
CRON_SCHEDULE=0 */6 * * *

# Timezone (set in Dockerfile; can be overridden here)
TZ=Asia/Shanghai
